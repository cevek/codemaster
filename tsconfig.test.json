{
  // Typecheck-only config covering tests (they import src/*.ts directly and run via
  // Node 22 native type stripping — no build step; see test/README.md).
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": true,
    "rootDir": ".",
    "outDir": null,
    "declaration": false,
    "declarationMap": false,
    "sourceMap": false
  },
  "include": ["src", "test"],
  // Committed repo-fixtures (test/fixtures/repos/*) are standalone mini-projects compiled
  // by their OWN tsconfig (e.g. kitchensink: jsx + enums + @/ alias + ambient stubs). They
  // must not be typechecked under the project's settings (erasableSyntaxOnly, NodeNext).
  "exclude": ["test/fixtures/repos"]
}
